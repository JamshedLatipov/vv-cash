<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VvCash.ViewModels"
        xmlns:views="using:VvCash.Views"
        x:Class="VvCash.Views.MainWindow"
        Title="VV Cash POS"
        Width="1440" Height="900"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PosViewModel}">
            <views:PosView />
        </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MixedPaymentViewModel}">
            <views:MixedPaymentView />
        </DataTemplate>
    </Window.DataTemplates>

    <TransitioningContentControl Content="{Binding CurrentViewModel}" />
</Window>
