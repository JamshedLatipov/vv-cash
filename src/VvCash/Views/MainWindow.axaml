<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VvCash.ViewModels"
        xmlns:models="using:VvCash.Models"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:converters="using:VvCash.Converters"
        x:Class="VvCash.Views.MainWindow"
        x:Name="RootWindow"
        Title="VV Cash POS"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="600"
        Background="#0f0f23">

    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>

    <Grid ColumnDefinitions="80,*,380">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#16163a" BorderBrush="#2a2a5a" BorderThickness="0,0,1,0">
            <StackPanel Spacing="4" Margin="4,16,4,4">
                <Button Classes="CategoryButton" Command="{Binding SelectCategoryCommand}" CommandParameter="All">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <material:MaterialIcon Kind="ViewGrid" Width="24" Height="24" />
                        <TextBlock Text="All" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="CategoryButton" Command="{Binding SelectCategoryCommand}" CommandParameter="Clothing">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <material:MaterialIcon Kind="TshirtCrew" Width="24" Height="24" />
                        <TextBlock Text="Clothing" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="CategoryButton" Command="{Binding SelectCategoryCommand}" CommandParameter="Shoes">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <material:MaterialIcon Kind="Shoe" Width="24" Height="24" />
                        <TextBlock Text="Shoes" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="CategoryButton" Command="{Binding SelectCategoryCommand}" CommandParameter="Accessories">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <material:MaterialIcon Kind="Watch" Width="24" Height="24" />
                        <TextBlock Text="Accs" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="CategoryButton" Command="{Binding SelectCategoryCommand}" CommandParameter="Sale">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <material:MaterialIcon Kind="Tag" Width="24" Height="24" />
                        <TextBlock Text="Sale" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Center: Product Grid -->
        <Grid Grid.Column="1" RowDefinitions="60,*,32">
            <!-- Top search bar -->
            <Border Grid.Row="0" Background="#16163a" Padding="12,8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchQuery}"
                             Watermark="Search products or scan barcode..."
                             Classes="SearchBox"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1"
                            Classes="PrimaryButton"
                            Command="{Binding SearchProductsCommand}"
                            Content="Search" Width="80"/>
                </Grid>
            </Border>

            <!-- Product grid -->
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Products}" Margin="12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:Product">
                            <Border Classes="ProductCard" Width="180" Margin="6" Cursor="Hand">
                                <Button Classes="Transparent"
                                        Command="{Binding DataContext.AddToCartCommand, ElementName=RootWindow}"
                                        CommandParameter="{Binding}"
                                        Padding="0">
                                    <Grid RowDefinitions="120,*">
                                        <!-- Image placeholder -->
                                        <Border Grid.Row="0" Background="#2a2a4e" CornerRadius="8,8,0,0">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <material:MaterialIcon Kind="Package" Width="48" Height="48" Foreground="#4a4a7a"/>
                                            </StackPanel>
                                            <!-- Discount badge -->
                                            <Border IsVisible="{Binding DiscountPercent, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                    Background="#f44336" CornerRadius="4"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,8,8,0" Padding="4,2">
                                                <TextBlock Foreground="White" FontSize="11" FontWeight="Bold"
                                                           Text="{Binding DiscountPercent, StringFormat='-{0:0}%'}"/>
                                            </Border>
                                        </Border>
                                        <!-- Info -->
                                        <StackPanel Grid.Row="1" Spacing="2" Margin="8,6">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White" TextWrapping="Wrap" MaxLines="2"/>
                                            <TextBlock Text="{Binding Sku}" FontSize="11" Foreground="#a0a0b8"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Price, StringFormat='${0:F2}'}"
                                                           FontSize="15" FontWeight="Bold" Foreground="#11b4d4"/>
                                                <TextBlock Text="{Binding OriginalPrice, StringFormat='${0:F2}'}"
                                                           FontSize="11" Foreground="#666688"
                                                           TextDecorations="Strikethrough"
                                                           IsVisible="{Binding OriginalPrice, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#16163a" Padding="12,0">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#a0a0b8" FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{Binding IsPrinterReady, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Text="{Binding PrinterStatusText}" Foreground="#a0a0b8" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right: Order Panel -->
        <Border Grid.Column="2" Background="#16163a" BorderBrush="#2a2a5a" BorderThickness="1,0,0,0">
            <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
                <!-- Header -->
                <Border Grid.Row="0" Padding="16,12" BorderBrush="#2a2a5a" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Current Order" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <Border Grid.Column="1" Background="#11b4d4" CornerRadius="12" Padding="8,2">
                            <TextBlock Text="{Binding CartItems.Count}" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Cart items -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding CartItems}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:CartItem">
                                <Border Background="#1e1e42" CornerRadius="8" Margin="0,4" Padding="10,8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding Product.Name}" FontSize="13" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Product.Sku}" FontSize="11" Foreground="#a0a0b8"/>
                                            <TextBlock Text="{Binding LineTotal, StringFormat='${0:F2}'}" FontSize="14" FontWeight="Bold" Foreground="#11b4d4"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                            <Button Classes="IconButton"
                                                    Command="{Binding DataContext.RemoveFromCartCommand, ElementName=RootWindow}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Right">
                                                <material:MaterialIcon Kind="Delete" Width="16" Height="16" Foreground="#f44336"/>
                                            </Button>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Button Classes="QtyButton"
                                                        Command="{Binding DataContext.DecreaseQuantityCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding}"
                                                        Content="-"/>
                                                <TextBlock Text="{Binding Quantity}" Width="24" TextAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                <Button Classes="QtyButton"
                                                        Command="{Binding DataContext.IncreaseQuantityCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding}"
                                                        Content="+"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Coupon section -->
                <Border Grid.Row="2" Padding="12,8" BorderBrush="#2a2a5a" BorderThickness="0,1,0,1">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding CouponCode}" Watermark="Coupon code..." Margin="0,0,6,0" Classes="SearchBox"/>
                            <Button Grid.Column="1" Content="Apply" Command="{Binding ApplyCouponCommand}" Classes="PrimaryButton" Width="60"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding AppliedCoupons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:Coupon">
                                    <Border Background="#11b4d4" CornerRadius="12" Margin="2" Padding="8,3">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Code}" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                            <Button Classes="Transparent" Padding="0"
                                                    Command="{Binding DataContext.RemoveCouponCommand, ElementName=RootWindow}"
                                                    CommandParameter="{Binding Code}">
                                                <material:MaterialIcon Kind="Close" Width="12" Height="12" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Totals -->
                <Border Grid.Row="3" Padding="16,10" BorderBrush="#2a2a5a" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Subtotal" Foreground="#a0a0b8" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat='${0:F2}'}" Foreground="White" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Tax (8.5%)" Foreground="#a0a0b8" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="{Binding Tax, StringFormat='${0:F2}'}" Foreground="White" FontSize="13"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Discount" Foreground="#4caf50" FontSize="13"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalDiscount, StringFormat='-${0:F2}'}" Foreground="#4caf50" FontSize="13"/>
                        </Grid>
                        <Border Height="1" Background="#2a2a5a" Margin="0,4"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="TOTAL" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat='${0:F2}'}" FontSize="20" FontWeight="Bold" Foreground="#11b4d4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action buttons -->
                <Grid Grid.Row="4" ColumnDefinitions="*,*" Margin="12,10">
                    <Button Grid.Column="0" Margin="0,0,6,0"
                            Classes="SecondaryButton"
                            Command="{Binding PrintReceiptCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon Kind="Printer" Width="18" Height="18"/>
                            <TextBlock Text="Print"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Margin="6,0,0,0"
                            Classes="PrimaryButton"
                            Command="{Binding PayCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon Kind="Cash" Width="18" Height="18"/>
                            <TextBlock Text="Pay"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
