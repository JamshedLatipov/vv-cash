<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VvCash.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        x:Class="VvCash.Views.SettingsView"
        Background="{StaticResource Slate50Brush}">

    <UserControl.Styles>
        <Style Selector="Button.BackButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Slate600Brush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.BackButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Slate200Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource Slate900Brush}"/>
        </Style>

        <Style Selector="Button.SaveButton">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style Selector="Button.SaveButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0d8fa6"/>
        </Style>

        <Style Selector="TextBox.SettingsInput">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Slate300Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource Slate900Brush}"/>
            <Setter Property="Margin" Value="0,8,0,24"/>
        </Style>
        <Style Selector="TextBox.SettingsInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Top Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Slate200Brush}" BorderThickness="0,0,0,1" Padding="16">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Classes="BackButton" Command="{Binding GoBackCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <material:MaterialIcon Kind="ArrowLeft" Width="24" Height="24"/>
                        <TextBlock Text="Back" VerticalAlignment="Center" FontSize="16" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="Settings" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="32">
            <StackPanel MaxWidth="600" HorizontalAlignment="Center" Spacing="0">

                <!-- Server Configuration Section -->
                <Border Background="White" BorderBrush="{StaticResource Slate200Brush}" BorderThickness="1" CornerRadius="12" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Server Configuration" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" Margin="0,0,0,16"/>

                        <TextBlock Text="Backend URL" FontSize="14" FontWeight="Medium" Foreground="{StaticResource Slate700Brush}"/>
                        <TextBox Classes="SettingsInput" Text="{Binding BackendUrl, Mode=TwoWay}" Watermark="https://api.example.com"/>

                        <TextBlock Text="Cash Register Token" FontSize="14" FontWeight="Medium" Foreground="{StaticResource Slate700Brush}"/>
                        <TextBox Classes="SettingsInput" Text="{Binding CashRegisterToken, Mode=TwoWay}" Watermark="Enter token" PasswordChar="•"/>

                    </StackPanel>
                </Border>

                <Button Classes="SaveButton" Content="Save Changes" Command="{Binding SaveCommand}"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
