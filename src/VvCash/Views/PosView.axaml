<UserControl x:Name="RootWindow" xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:VvCash.Services"
        xmlns:vm="using:VvCash.ViewModels"
        xmlns:models="using:VvCash.Models"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:converters="using:VvCash.Converters"
        x:Class="VvCash.Views.PosView"




        Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <converters:StringEqualityToBoolConverter x:Key="StringEqualityToBoolConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Background="{StaticResource BackgroundBrush}">
        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" BorderBrush="{StaticResource Slate200Brush}" BorderThickness="0,0,0,1" Padding="24,12" ZIndex="10">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="PackageVariant" Width="28" Height="28" Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="{Binding [LuxeThreadsPOS], Source={x:Static services:I18nService.Instance}}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Width="1" Background="{StaticResource Slate200Brush}" Margin="8,0" Height="24"/>
                    <Border Background="{StaticResource Slate100Brush}" CornerRadius="8" Padding="12,8" Width="300">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="Magnify" Width="20" Height="20" Foreground="{StaticResource Slate500Brush}"/>
                            <TextBox Text="{Binding SearchQuery}" Watermark="{Binding [Searchproductsorscan], Source={x:Static services:I18nService.Instance}}" Classes="SearchBox" Padding="0" VerticalAlignment="Center" Width="250" FontSize="14" Foreground="{StaticResource Slate900Brush}" KeyDown="OnSearchBoxKeyDown"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <Button Classes="NavButton" Content="Orders" Margin="0,0,16,0" FontSize="14"/>
                    <Button Classes="NavButton" Content="Inventory" Margin="0,0,16,0" FontSize="14"/>
                    <Button Classes="NavButton" Content="Клиенты" Command="{Binding OpenCustomerSearchCommand}" Margin="0,0,16,0" FontSize="14"/>
                    <Button Classes="NavButton" Content="Создать клиента" Command="{Binding OpenCustomerRegistrationCommand}" Margin="0,0,16,0" FontSize="14"/>
                    <Button Classes="IconButton" Margin="0,0,8,0" Command="{Binding FullReinitializeCommand}" ToolTip.Tip="Sync Data"><material:MaterialIcon Kind="Sync" Width="24" Height="24" Foreground="{StaticResource Slate600Brush}"/></Button>

<Button Classes="IconButton" Margin="0,0,8,0" Command="{Binding CloseShiftCommand}" ToolTip.Tip="Close Shift">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="!IsLoadingShift"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Panel Width="24" Height="24">
                            <material:MaterialIcon Kind="CloseBoxOutline" Width="24" Height="24"
                                                   Foreground="{Binding IsShiftOpen, Converter={StaticResource BoolToColorConverter}}"
                                                   IsVisible="{Binding !IsLoadingShift}"/>
                            <ProgressBar IsIndeterminate="True" Width="24" Height="24"
                                         Foreground="{StaticResource Slate500Brush}"
                                         IsVisible="{Binding IsLoadingShift}"/>
                        </Panel>
                    </Button>
                    <Button Classes="IconButton" Margin="0,0,8,0" Command="{Binding CloseApplicationCommand}" ToolTip.Tip="Exit">
                        <material:MaterialIcon Kind="Power" Width="24" Height="24" Foreground="{StaticResource Slate700Brush}"/>
                    </Button>
                    <Button Classes="IconButton" Margin="0,0,8,0">
                        <material:MaterialIcon Kind="History" Width="24" Height="24" Foreground="{StaticResource Slate700Brush}"/>
                    </Button>
                    <Button Classes="IconButton">
                        <material:MaterialIcon Kind="AccountCircle" Width="24" Height="24" Foreground="{StaticResource Slate700Brush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Margin="24">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="Transparent" Width="80" Margin="0,0,24,0" VerticalAlignment="Top" ZIndex="2">
                <StackPanel Spacing="16">
                    <Button Classes="CategoryButton" Classes.Active="{Binding IsViewingCategories}" Command="{Binding SelectCategoryCommand}">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <material:MaterialIcon Kind="ViewGrid" Width="24" Height="24" />
                            <TextBlock Text="{Binding [ALL], Source={x:Static services:I18nService.Instance}}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" LetterSpacing="1"/>
                        </StackPanel>
                    </Button>
                    <ItemsControl ItemsSource="{Binding QuickCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:Category">
                                <Button Classes="CategoryButton"
                                        Command="{Binding DataContext.SelectCategoryCommand, ElementName=RootWindow}"
                                        CommandParameter="{Binding}">
                                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                                        <material:MaterialIcon Kind="FolderOutline" Width="24" Height="24" />
                                        <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" LetterSpacing="1" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- SplitView for Catalog Drawer and Main Content -->
            <SplitView Grid.Column="1" IsPaneOpen="{Binding IsCatalogOpen, Mode=TwoWay}" DisplayMode="Overlay" OpenPaneLength="500" PanePlacement="Left" Background="Transparent" PaneBackground="Transparent" ZIndex="1">
                <SplitView.Pane>
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource Slate200Brush}" BorderThickness="0,0,1,0" Padding="0,0,24,0">
                        <Grid RowDefinitions="Auto, *">
                            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                                <TextBlock Grid.Column="0" Text="{Binding SelectedCategoryName, StringFormat='{}{0}'}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Classes="IconButton" Command="{Binding CloseCatalogCommand}" VerticalAlignment="Center">
                                    <material:MaterialIcon Kind="Close" Width="24" Height="24" Foreground="{StaticResource Slate700Brush}"/>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1">
                                <StackPanel Spacing="0">
                                <ItemsControl ItemsSource="{Binding AllCategories}" IsVisible="{Binding IsViewingCategories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:Category">
                                            <Border Width="220" Height="100" Margin="0,0,16,16" Cursor="Hand" BorderBrush="{StaticResource Slate200Brush}" BorderThickness="1" Background="White" CornerRadius="8">
                                                <Button Classes="Transparent"
                                                        Command="{Binding DataContext.SelectCategoryCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding}"
                                                        Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                                        <material:MaterialIcon Kind="FolderOutline" Width="32" Height="32" Foreground="{StaticResource Slate500Brush}"/>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource Slate900Brush}" TextAlignment="Center" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Button>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding Products}" IsVisible="{Binding !IsViewingCategories}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="models:Product">
                                            <Border Classes="ProductCard" Width="220" Margin="0,0,16,16" Cursor="Hand" BorderBrush="{StaticResource Slate100Brush}" BorderThickness="1" Background="White">
                                                <Button Classes="Transparent"
                                                        Command="{Binding DataContext.AddToCartCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding}"
                                                        Padding="0">
                                                    <Grid RowDefinitions="160,*">
                                                        <!-- Image placeholder -->
                                                        <Panel Grid.Row="0" Background="{StaticResource Slate50Brush}">
                                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <material:MaterialIcon Kind="ImageOutline" Width="48" Height="48" Foreground="{StaticResource Slate300Brush}"/>
                                                            </StackPanel>
                                                            <!-- Discount badge -->
                                                            <Border IsVisible="{Binding DiscountPercent, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                    Background="{StaticResource Red100Brush}" CornerRadius="4" Padding="6,2"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                                                                <TextBlock Text="{Binding DiscountPercent, StringFormat='-{0}%'}" Foreground="{StaticResource Red600Brush}" FontSize="11" FontWeight="Black"/>
                                                            </Border>
                                                        </Panel>

                                                        <!-- Product details -->
                                                        <Border Grid.Row="1" Padding="12">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource Slate900Brush}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Sku, StringFormat='SKU: {0}'}" FontSize="12" Foreground="{StaticResource Slate500Brush}"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                                                    <TextBlock Text="{Binding Price, StringFormat='${0:F2}'}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource Slate900Brush}"/>
                                                                    <TextBlock Text="{Binding OriginalPrice, StringFormat='${0:F2}'}"
                                                                               IsVisible="{Binding OriginalPrice, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                               Foreground="{StaticResource Slate400Brush}" FontSize="12" TextDecorations="Strikethrough" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </SplitView.Pane>

                <SplitView.Content>
                    <!-- Current Order Main Panel -->
                    <Grid RowDefinitions="Auto, *, Auto">

                        <!-- Current Order Header -->
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,24" VerticalAlignment="Bottom">
                            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding [CurrentOrder], Source={x:Static services:I18nService.Instance}}" FontSize="30" FontWeight="ExtraBold" Foreground="{StaticResource Slate900Brush}" LetterSpacing="-0.5"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding [Order8429], Source={x:Static services:I18nService.Instance}}" FontWeight="Medium" Foreground="{StaticResource Slate500Brush}" FontSize="14"/>
                                    <Ellipse Width="4" Height="4" Fill="{StaticResource Slate300Brush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding [Terminal01], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource Slate500Brush}" FontSize="14"/>
                                    <Ellipse Width="4" Height="4" Fill="{StaticResource Slate300Brush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding [Oct242023245PM], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource Slate500Brush}" FontSize="14"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1" Classes="SecondaryButton" Command="{Binding ClearCartCommand}" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <material:MaterialIcon Kind="Delete" Width="18" Height="18" Foreground="{StaticResource Slate700Brush}"/>
                                    <TextBlock Text="{Binding [ClearCart], Source={x:Static services:I18nService.Instance}}" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Cart Items List -->
                        <ScrollViewer Grid.Row="1" Margin="0,0,8,24">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:CartItem">
                                        <Border Background="White" CornerRadius="12" Margin="0,0,0,16" Padding="16" BorderBrush="{StaticResource Slate100Brush}" BorderThickness="1">
                                            <Grid ColumnDefinitions="100, *, Auto, Auto">
                                                <!-- Image -->
                                                <Border Grid.Column="0" Background="{StaticResource Slate50Brush}" CornerRadius="8" Width="96" Height="96" HorizontalAlignment="Left" BorderBrush="{StaticResource Slate100Brush}" BorderThickness="1" ClipToBounds="True">
                                                    <Panel>
                                                        <material:MaterialIcon Kind="ImageOutline" Width="32" Height="32" Foreground="{StaticResource Slate400Brush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        <!-- If ImagePath is valid, we would bind an Image here -->
                                                    </Panel>
                                                </Border>

                                                <!-- Details -->
                                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Top" Margin="16,0,0,0">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding Product.Name}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}"/>
                                                            <Border IsVisible="{Binding Product.DiscountPercent, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                    Background="{StaticResource Red100Brush}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Product.DiscountPercent, StringFormat='-{0}%'}" Foreground="{StaticResource Red600Brush}" FontSize="12" FontWeight="Black" LetterSpacing="1" Classes="Uppercase"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding LineTotal, StringFormat='${0:F2}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{Binding LineTotalOriginal, StringFormat='${0:F2}'}"
                                                                       IsVisible="{Binding Product.DiscountPercent, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                       Foreground="{StaticResource Slate400Brush}" FontSize="12" TextDecorations="Strikethrough" HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="{Binding Product.Sku, StringFormat='SKU: {0}'}" FontSize="14" Foreground="{StaticResource Slate500Brush}"/>

                                                    <!-- Labels / Badges -->
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                        <Border IsVisible="{Binding Product.DiscountPercent, Converter={x:Static ObjectConverters.IsNull}}"
                                                                Background="{StaticResource PrimaryLightBrush}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding [NEWARRIVAL], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="Bold" LetterSpacing="1"/>
                                                        </Border>
                                                        <TextBlock IsVisible="{Binding Product.DiscountPercent, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                   Text="{Binding [SeasonalDiscountAppl], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource Red500Brush}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Quantity Controls -->
                                                <Border Grid.Column="2" Background="{StaticResource Slate50Brush}" CornerRadius="8" Padding="8" VerticalAlignment="Center" Margin="16,0,8,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <Button Classes="QtyButton"
                                                                Command="{Binding DataContext.DecreaseQuantityCommand, ElementName=RootWindow}"
                                                                CommandParameter="{Binding}"
                                                                Content="-"/>
                                                        <TextBlock Text="{Binding Quantity}" Width="24" TextAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Slate900Brush}" FontWeight="Bold" FontSize="18"/>
                                                        <Button Classes="QtyButton"
                                                                Command="{Binding DataContext.IncreaseQuantityCommand, ElementName=RootWindow}"
                                                                CommandParameter="{Binding}"
                                                                Content="+"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Delete Button -->
                                                <Button Grid.Column="3" Classes="CartIconButton"
                                                        Command="{Binding DataContext.RemoveFromCartCommand, ElementName=RootWindow}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center">
                                                    <material:MaterialIcon Kind="Delete" Width="24" Height="24"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Totals & Pay Section -->
                        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="24" BorderBrush="{StaticResource Slate200Brush}" BorderThickness="1" Margin="0,0,0,0">
                            <Grid RowDefinitions="Auto, Auto">
                                <Grid Grid.Row="0" ColumnDefinitions="*, *" Margin="0,0,0,24">
                                    <!-- Promotions -->
                                    <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,32,0">
                                        <TextBlock Text="{Binding [PROMOTIONSampCOUPONS], Source={x:Static services:I18nService.Instance}}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" LetterSpacing="1"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBox Grid.Column="0" Text="{Binding CouponCode}" Watermark="{Binding [Entercouponcode], Source={x:Static services:I18nService.Instance}}" Margin="0,0,8,0" Classes="CouponBox"/>
                                            <Button Grid.Column="1" Content="{Binding [Apply], Source={x:Static services:I18nService.Instance}}" Command="{Binding ApplyCouponCommand}" Classes="SecondaryButton" Width="80"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding AppliedCoupons}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:Coupon">
                                                    <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="16" Margin="0,8,8,0" Padding="12,4">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <material:MaterialIcon Kind="TicketConfirmation" Width="16" Height="16" Foreground="{StaticResource PrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Code}" FontSize="12" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"/>
                                                            <Button Classes="Transparent" Padding="0" Margin="4,0,0,0"
                                                                    Command="{Binding DataContext.RemoveCouponCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding Code}">
                                                                <material:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Totals List -->
                                    <StackPanel Grid.Column="1" Spacing="12" Margin="32,0,0,0">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding [Subtotal], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource Slate600Brush}" FontSize="16"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat='${0:F2}'}" Foreground="{StaticResource Slate900Brush}" FontSize="16" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding [Tax85], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource Slate600Brush}" FontSize="16"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Tax, StringFormat='${0:F2}'}" Foreground="{StaticResource Slate900Brush}" FontSize="16" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                                                <material:MaterialIcon Kind="Tag" Width="16" Height="16" Foreground="{StaticResource Red500Brush}"/>
                                                <TextBlock Text="{Binding [TotalDiscount], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource Red500Brush}" FontSize="16" FontWeight="Medium"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalDiscount, StringFormat='-${0:F2}'}" Foreground="{StaticResource Red500Brush}" FontSize="16" FontWeight="Bold"/>
                                        </Grid>

                                        <Border Height="1" Background="{StaticResource Slate100Brush}" Margin="0,4"/>

                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding [TotalAmount], Source={x:Static services:I18nService.Instance}}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" VerticalAlignment="Bottom"/>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat='${0:F2}'}" FontSize="36" FontWeight="Black" Foreground="{StaticResource Slate900Brush}" LetterSpacing="-1"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- Action Buttons -->
                                <Grid Grid.Row="1" ColumnDefinitions="1*, 3*">
                                    <Button Grid.Column="0" Margin="0,0,16,0" Classes="SecondaryButton" Command="{Binding PrintReceiptCommand}" MinHeight="80" Background="{StaticResource Slate100Brush}" CornerRadius="12" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <material:MaterialIcon Kind="Printer" Width="28" Height="28" Foreground="{StaticResource Slate700Brush}"/>
                                            <TextBlock Text="{Binding [Print], Source={x:Static services:I18nService.Instance}}" FontSize="22" FontWeight="Black" Foreground="{StaticResource Slate700Brush}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1" Classes="PrimaryButton" Command="{Binding PayCommand}" MinHeight="80" CornerRadius="12" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <material:MaterialIcon Kind="CashMultiple" Width="36" Height="36"/>
                                            <TextBlock Text="{Binding TotalAmount, StringFormat='${0:F2}'}" FontSize="28" FontWeight="Black"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </SplitView.Content>
            </SplitView>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource Slate50Brush}" BorderBrush="{StaticResource Slate200Brush}" BorderThickness="0,1,0,0" Padding="24,8">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="6" Height="6" Fill="{Binding IsSystemOnline, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Text="{Binding SystemStatusText}" Foreground="{StaticResource Slate400Brush}" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="6" Height="6" Fill="{Binding IsPrinterReady, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Text="{Binding PrinterStatusText}" Foreground="{StaticResource Slate400Brush}" FontSize="10" FontWeight="Bold" LetterSpacing="1" Classes="Uppercase"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasUnsyncedDocuments}">
                        <material:MaterialIcon Kind="CloudOffOutline" Width="14" Height="14" Foreground="#ef4444"/>
                        <TextBlock Text="{Binding UnsyncedDocumentsCount, StringFormat={}{0} unsynced orders}" Foreground="#ef4444" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource Slate400Brush}" FontSize="10" Margin="0,0,24,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding [V240TERMINALIDLXP099], Source={x:Static services:I18nService.Instance}}" Foreground="{StaticResource Slate400Brush}" FontSize="10" FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Product Not Found Alert Modal -->
        <Border Grid.RowSpan="3" Background="#80000000"
                IsVisible="{Binding IsAlertModalVisible}"
                ZIndex="2000">
            <Border Background="{StaticResource BackgroundBrush}"
                    CornerRadius="16"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400">
                <StackPanel Spacing="24">
                    <material:MaterialIcon Kind="AlertCircleOutline" Width="64" Height="64" Foreground="#ef4444" HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding [Товарненайден], Source={x:Static services:I18nService.Instance}}"
                             FontSize="24"
                             FontWeight="Bold"
                             Foreground="{StaticResource Slate900Brush}"
                             HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding AlertMessage}"
                             FontSize="14"
                             Foreground="{StaticResource Slate600Brush}"
                             TextWrapping="Wrap"
                             TextAlignment="Center"/>

                    <Button Classes="PrimaryButton"
                            Content="ОК"
                            Command="{Binding CloseAlertModalCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="48"
                            FontSize="16"
                            Background="#ef4444"
                            FontWeight="Bold">
                    </Button>
                </StackPanel>
            </Border>
        </Border>

        <!-- Start Shift Modal Overlay -->
        <Border Grid.RowSpan="3"
                Background="#80000000"
                IsVisible="{Binding IsShiftModalVisible}"
                ZIndex="1000">
            <Border Background="{StaticResource BackgroundBrush}"
                    CornerRadius="16"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400">
                <StackPanel Spacing="24">
                    <material:MaterialIcon Kind="CashRegister" Width="64" Height="64" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding [StartShift], Source={x:Static services:I18nService.Instance}}"
                             FontSize="24"
                             FontWeight="Bold"
                             Foreground="{StaticResource Slate900Brush}"
                             HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding [Pleasestartyourshift], Source={x:Static services:I18nService.Instance}}"
                             FontSize="14"
                             Foreground="{StaticResource Slate600Brush}"
                             TextWrapping="Wrap"
                             TextAlignment="Center"/>

                    <Button Classes="PrimaryButton"
                            Content="START SHIFT"
                            Command="{Binding OpenShiftCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="48"
                            FontSize="16"
                            FontWeight="Bold">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="!IsLoadingShift"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                    </Button>

                    <Button Classes="OutlineButton"
                            Content="EXIT APPLICATION"
                            Command="{Binding CloseApplicationCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Height="48"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
