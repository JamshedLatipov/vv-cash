<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VvCash.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        x:Class="VvCash.Views.LoginView"
        Background="{StaticResource Slate50Brush}">

    <UserControl.Styles>
        <Style Selector="TextBox.LoginInput">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Slate200Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource Slate800Brush}"/>
            <Setter Property="Margin" Value="0,8,0,24"/>
        </Style>
        <Style Selector="TextBox.LoginInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="Button.LoginButton">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
            <Setter Property="Height" Value="56"/>
        </Style>
        <Style Selector="Button.LoginButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0d8fa6"/> <!-- A bit darker than PrimaryBrush (#11b4d4) -->
        </Style>
        <Style Selector="Button.LoginButton:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Slate300Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource Slate500Brush}"/>
        </Style>

        <Style Selector="Button.SettingsButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Slate400Brush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style Selector="Button.SettingsButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Slate200Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource Slate600Brush}"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*, *" Background="{StaticResource Slate50Brush}">
        <!-- Left Side: Branding/Info -->

        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" CornerRadius="0,24,24,0" Padding="48">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                <material:MaterialIcon Kind="PackageVariant" Width="120" Height="120" Foreground="White" />
                <TextBlock Text="Luxe Threads POS" FontSize="48" FontWeight="Black" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="Welcome back! Please enter your credentials to continue." FontSize="20" Foreground="{StaticResource Slate100Brush}" TextAlignment="Center" TextWrapping="Wrap" Opacity="0.9"/>
            </StackPanel>
        </Border>

        <!-- Right Side: Email/Password Entry -->
        <Border Grid.Column="1" Padding="48">
            <Grid>
                <!-- Settings Button -->
                <Button Classes="SettingsButton" VerticalAlignment="Top" HorizontalAlignment="Right" Command="{Binding OpenSettingsCommand}">
                    <material:MaterialIcon Kind="Cog" Width="28" Height="28" Foreground="{StaticResource Slate400Brush}" />
                </Button>

                <StackPanel MaxWidth="400" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <TextBlock Text="Sign In" FontSize="36" FontWeight="Black" Foreground="{StaticResource Slate900Brush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Red500Brush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- Email -->
                    <TextBlock Text="Email Address" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Slate700Brush}" Margin="0,0,0,4"/>
                    <TextBox Classes="LoginInput" Text="{Binding Email, Mode=TwoWay}" Watermark="Enter your email" IsEnabled="{Binding !IsBusy}"/>

                    <!-- Password -->
                    <TextBlock Text="Password" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Slate700Brush}" Margin="0,0,0,4"/>
                    <TextBox Classes="LoginInput" Text="{Binding Password, Mode=TwoWay}" Watermark="Enter your password" PasswordChar="•" IsEnabled="{Binding !IsBusy}"/>

                    <!-- Login Button -->
                    <Button Classes="LoginButton" Command="{Binding LoginCommand}" IsEnabled="{Binding !IsBusy}">
                        <Panel>
                            <TextBlock Text="Login" IsVisible="{Binding !IsBusy}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsBusy}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <material:MaterialIcon Kind="Loading" Classes="spin" Width="20" Height="20"/>
                                <TextBlock Text="Authenticating..." VerticalAlignment="Center" FontSize="16"/>
                            </StackPanel>
                        </Panel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
