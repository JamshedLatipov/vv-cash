<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VvCash.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="800"
        x:Class="VvCash.Views.CustomerRegistrationWindow"
        x:DataType="vm:CustomerRegistrationViewModel"
        Title="Customer Registration"
        Width="1024" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        CornerRadius="12"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Border Background="White" CornerRadius="12" ClipToBounds="True" BoxShadow="0 20 25 -5 #40000000">
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Border Grid.Row="0" BorderBrush="{StaticResource Slate100Brush}" BorderThickness="0,0,0,1" Padding="32,24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="AccountPlus" Width="36" Height="36" Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="Регистрация клиента" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="Transparent" Command="{Binding CancelCommand}" Padding="8" CornerRadius="99" Background="Transparent">
                        <material:MaterialIcon Kind="Close" Width="24" Height="24" Foreground="{StaticResource Slate500Brush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content Grid -->
            <Grid Grid.Row="1" ColumnDefinitions="*, 400">

                <!-- Left Side: Form Fields -->
                <ScrollViewer Grid.Column="0" BorderBrush="{StaticResource Slate100Brush}" BorderThickness="0,0,1,0" Padding="32">
                    <StackPanel Spacing="24">

                        <!-- Full Name -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="ФИО" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Slate600Brush}" Classes="Uppercase" LetterSpacing="1"/>
                            <TextBox Text="{Binding FullName}" Classes="IconTextBox" Watermark="Иван Иванов" FontSize="18">
                                <TextBox.InnerLeftContent>
                                    <material:MaterialIcon Kind="BadgeAccountHorizontalOutline" Width="24" Height="24" Foreground="{StaticResource Slate400Brush}" Margin="16,0,12,0"/>
                                </TextBox.InnerLeftContent>
                            </TextBox>
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="EMAIL" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Slate600Brush}" Classes="Uppercase" LetterSpacing="1"/>
                            <TextBox Text="{Binding Email}" Classes="IconTextBox" Watermark="example@mail.com" FontSize="18">
                                <TextBox.InnerLeftContent>
                                    <material:MaterialIcon Kind="EmailOutline" Width="24" Height="24" Foreground="{StaticResource Slate400Brush}" Margin="16,0,12,0"/>
                                </TextBox.InnerLeftContent>
                            </TextBox>
                        </StackPanel>

                        <!-- Date of Birth -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="ДАТА РОЖДЕНИЯ" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Slate600Brush}" Classes="Uppercase" LetterSpacing="1"/>
                            <CalendarDatePicker SelectedDate="{Binding DateOfBirth}"
                                                Watermark="ДД.ММ.ГГГГ"
                                                HorizontalAlignment="Stretch"
                                                Height="56"
                                                FontSize="18"
                                                CornerRadius="12"
                                                BorderBrush="{StaticResource Slate200Brush}"
                                                BorderThickness="2" />
                        </StackPanel>

                        <!-- Loyalty Program Toggle -->
                        <Border Background="{StaticResource PrimaryLightBrush}" BorderBrush="{StaticResource PrimaryLightBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <material:MaterialIcon Grid.Column="0" Kind="CardAccountDetailsOutline" Width="32" Height="32" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Программа лояльности" FontWeight="Bold" FontSize="16" Foreground="{StaticResource Slate900Brush}"/>
                                    <TextBlock Text="Начисление бонусов с первой покупки" FontSize="12" Foreground="{StaticResource Slate500Brush}"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="2" IsChecked="{Binding IsLoyaltyEnrolled}" OnContent="" OffContent="" VerticalAlignment="Center" Classes="PrimarySwitch"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Right Side: Phone Number & Numpad -->
                <Border Grid.Column="1" Background="{StaticResource Slate50Brush}" Padding="32">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
                            <TextBlock Text="НОМЕР ТЕЛЕФОНА" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Slate600Brush}" Classes="Uppercase" LetterSpacing="1"/>
                            <Border Background="White" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" CornerRadius="12" Height="64" Padding="16">
                                <TextBlock Text="{Binding FormattedPhoneNumber}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Slate900Brush}" TextAlignment="Center" VerticalAlignment="Center" LetterSpacing="2"/>
                            </Border>
                        </StackPanel>

                        <!-- Touch Optimized Numpad -->
                        <Grid Grid.Row="1" RowDefinitions="*,*,*,*" ColumnDefinitions="*,*,*">
                            <!-- Row 1 -->
                            <Button Grid.Row="0" Grid.Column="0" Content="1" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="1" Margin="6"/>
                            <Button Grid.Row="0" Grid.Column="1" Content="2" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="2" Margin="6"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="3" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="3" Margin="6"/>

                            <!-- Row 2 -->
                            <Button Grid.Row="1" Grid.Column="0" Content="4" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="4" Margin="6"/>
                            <Button Grid.Row="1" Grid.Column="1" Content="5" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="5" Margin="6"/>
                            <Button Grid.Row="1" Grid.Column="2" Content="6" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="6" Margin="6"/>

                            <!-- Row 3 -->
                            <Button Grid.Row="2" Grid.Column="0" Content="7" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="7" Margin="6"/>
                            <Button Grid.Row="2" Grid.Column="1" Content="8" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="8" Margin="6"/>
                            <Button Grid.Row="2" Grid.Column="2" Content="9" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="9" Margin="6"/>

                            <!-- Row 4 -->
                            <Button Grid.Row="3" Grid.Column="0" Classes="NumpadActionButton" Command="{Binding BackspaceCommand}" Margin="6">
                                <material:MaterialIcon Kind="Backspace" Width="32" Height="32"/>
                            </Button>
                            <Button Grid.Row="3" Grid.Column="1" Content="0" Classes="NumpadButton" Command="{Binding NumpadCommand}" CommandParameter="0" Margin="6"/>
                            <Button Grid.Row="3" Grid.Column="2" Classes="NumpadActionButton" Command="{Binding SubmitCommand}" Margin="6">
                                <material:MaterialIcon Kind="CheckCircle" Width="32" Height="32"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer Actions -->
            <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Slate100Brush}" BorderThickness="0,1,0,0" Padding="32">
                <Grid ColumnDefinitions="1*, 2*">
                    <Button Grid.Column="0" Content="ОТМЕНА" Classes="OutlinedButton" Command="{Binding CancelCommand}" Margin="0,0,16,0" HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="1" Classes="PrimaryButton" Command="{Binding SubmitCommand}" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="AccountPlus" Width="24" Height="24"/>
                            <TextBlock Text="ЗАРЕГИСТРИРОВАТЬ КЛИЕНТА" Classes="Uppercase" LetterSpacing="1" FontSize="16"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>